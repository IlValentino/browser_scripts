// ==UserScript==
// @name         YouTube Default 4–20 Min Search
// @namespace    tampermonkey-ytduration-default
// @version      1.0
// @description  If a YouTube search has no length filter, default to 4–20 minutes. Do nothing if a length filter was chosen.
// @match        https://www.youtube.com/*
// @run-at       document-start
// @grant        none
// ==/UserScript==

(function () {
  'use strict';

  // Duration codes:
  // Short (<4):  EgIYAQ==
  // Long (20+):  EgIYAg==
  // 4–20 min:    EgIYAw==
  const MID_DURATION_SP = 'EgIYAw==';

  function shouldApply(url) {
    try {
      const u = new URL(url);
      if (u.pathname !== '/results') return false;

      const q = u.searchParams.get('search_query');
      if (!q) return false; // Not a search

      // If any 'sp' is present, we assume user selected a filter (including duration). Do nothing.
      const sp = u.searchParams.get('sp');
      if (sp) return false;

      return true;
    } catch (e) {
      return false;
    }
  }

  function applyDefaultDuration(url) {
    const u = new URL(url);
    u.searchParams.set('sp', MID_DURATION_SP); // URLSearchParams will encode to EgIYAw%3D%3D
    return u.toString();
  }

  function handle() {
    const href = location.href;
    if (shouldApply(href)) {
      // Use location.replace to avoid extra history entry and prevent loops.
      location.replace(applyDefaultDuration(href));
    }
  }

  // Initial check
  handle();

  // YouTube is an SPA; listen for navigation events
  // Modern YT dispatches 'yt-navigate-finish' on SPA transitions
  window.addEventListener('yt-navigate-finish', handle);

  // Fallbacks
  window.addEventListener('popstate', handle);
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) handle();
  });
})();
